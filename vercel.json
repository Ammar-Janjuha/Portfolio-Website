{
  "version": 2,

  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "s-maxage=31536000,immutable"
      }
    },
    {
      "src": "/contact",
      "dest": "/api/contact.js"
    },
    {
      "src": "/subscribe",
      "dest": "/api/subscribe.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
